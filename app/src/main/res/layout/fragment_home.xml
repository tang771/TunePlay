<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_home"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background">

    <!-- Scrollable content below search -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Search box (always at top) -->
            <FrameLayout
                android:id="@+id/search_container"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="@dimen/grid_2"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_glass_search">

                <ImageView
                    android:id="@+id/iv_search_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="12dp"
                    android:alpha="0.6"
                    android:contentDescription="Search"
                    android:src="@drawable/ic_search_24" />

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="44dp"
                    android:layout_marginEnd="40dp"
                    android:background="@null"
                    android:hint="@string/search_hint"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_caption"
                    android:textSize="@dimen/text_body" />

                <ImageButton
                    android:id="@+id/btn_search_clear"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Clear search"
                    android:src="@drawable/ic_close"
                    android:tint="@color/text_caption"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Cover carousel -->
            <LinearLayout
                android:id="@+id/carousel_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/grid_2"
                android:layout_marginTop="4dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/carousel_label"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginBottom="2dp"
                    android:gravity="center_vertical"
                    android:text="@string/carousel_label"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/carousel"
                    android:layout_width="match_parent"
                    android:layout_height="210dp"
                    android:background="@drawable/bg_carousel"
                    android:clipToOutline="true" />
            </LinearLayout>

            <!-- Recommendations + playlists + discover (always visible) -->
            <LinearLayout
                android:id="@+id/content_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/grid_2"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/recommend_label"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="2dp"
                    android:gravity="center_vertical"
                    android:text="@string/recommend_label"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recommended_rv"
                    android:layout_width="match_parent"
                    android:layout_height="170dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:padding="0dp" />

                <TextView
                    android:id="@+id/playlist_label"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="2dp"
                    android:gravity="center_vertical"
                    android:text="@string/playlist_recommend_label"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/playlist_rv"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:padding="0dp" />

                <TextView
                    android:id="@+id/discover_label"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="2dp"
                    android:gravity="center_vertical"
                    android:text="@string/discover_label"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/discover_rv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:padding="0dp" />

                <TextView
                    android:id="@+id/footer_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/footer_hint"
                    android:textColor="@color/text_caption"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
